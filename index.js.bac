// Define the function declaration for getting Margin Penjualan from API
const getMarginPenjualanDeclaration = {
  name: 'get_margin_penjualan',
  description: 'Mendapatkan data penjualan untuk menentukan margin atau keuntungan penjualannya berdasarkan kriteria tertentu, seperti tanggal.',
  parameters: {
    type: Type.OBJECT,
    properties: {
      tanggal: {
        type: Type.STRING,
        description: 'Tanggal penjualan yang ingin dicari, formatnya tanggal yang dicari (YYYY-MM-DD). Contoh:"2025-05-14',
      },
    },
    required: ['tanggal'],
  },
};
// (Deklarasi fungsi)
async function callGemini(userQuery){
  return await ai.models.generateContent({
      model: 'gemini-2.0-flash',
      contents: userQuery,
    });
  }

async function main() {
  const userQuery = "Berapakah total keuntungan saya dari penjualan tanggal 3 maret 2025?";

  const response = await ai.models.generateContent({
    model: 'gemini-2.0-flash',
    contents: userQuery,
    config: {
      tools: [{
        functionDeclarations: [
          getSalesDetailsFunctionDeclaration, getSalesMarketplaceFunction, getMarginPenjualanDeclaration,
          getTotalItemFunction, getTotalCashFunction,getTotalNonCashFunction, getPembelianFunction,
          getServiceFunction,getStockHutangFunction, getPesananOpenFunction, getPesananDoneFunction,
          getPesananFinishFunction,getDataOpnameFunction,getManagerialAnalysisFunction, getFullSummaryFunction,// Tambahkan deklarasi fungsi getSalesDetails
        ],
      }],
    },
  });

  // Check for function calls in the response
  if (response.functionCalls && response.functionCalls.length > 0) {
    for (const functionCall of response.functionCalls) {
      console.log(`Fungsi yang dipanggil: ${functionCall.name}`);
      console.log(`Argumen: ${JSON.stringify(functionCall.args)}`);

      let result;
      if (functionCall.name === 'get_sales_details') {
        result = await getSalesDetails(functionCall.args); // Panggil fungsi getSalesDetails
      } else if(functionCall.name === 'get_sales_marketplace'){
        result = await getSalesMarketplace(functionCall.args);
      } else if (functionCall.name === "get_total_item"){
        result = await getTotalBarang(functionCall.args)
      } else if (functionCall.name === "get_total_cash"){
        result = await getTotalCash(functionCall.args)
      } else if (functionCall.name === 'get_total_noncash'){
        result = await getTotalNonCash(functionCall.args)
      } else if (functionCall.name === 'get_pembelian'){
        result = await getPembelian(functionCall.args)
      } else if (functionCall.name === 'get_service'){
        result = await getService(functionCall.args)
      } else if (functionCall.name === 'get_stock_hutang'){
        result = await getStockHutang(functionCall.args)
      }  else if (functionCall.name === 'get_pesanan_open'){
        result = await getPesananOpen(functionCall.args)
      } else if (functionCall.name === 'get_pesanan_done'){
        result = await getPesananDone(functionCall.args)
      } else if (functionCall.name === 'get_pesanan_finish'){
        result = await getPesananFinish(functionCall.args)
      } else if (functionCall.name === 'get_data_opname'){
        result = await getDataOpname(functionCall.args)
      } else if (functionCall.name === 'get_managerial_analysis'){
        result = await getManagerialAnalysis(functionCall.args)
      } else if (functionCall.name === 'get_full_summary'){
        result = await getFullSummary(functionCall.args)
      } else if (functionCall.name === 'get_margin_penjualan'){
        result = await getMarginPenjualan(functionCall.args)
      }


      if (result) {
        console.log(`Hasil fungsi ${functionCall.name}: ${JSON.stringify(result)}`);
        var finalResult = await callGemini(`
          tolong ubah hasil jawaban dari fungsi gemini menjadi kalimat yang mudah dipahami.
          ini hasilnya:

          ${JSON.stringify(result)}
          `)
          console.log(finalResult.candidates[0].content.parts.map((e) => e.text).join());
        // Kirimkan hasil ini kembali ke model jika diperlukan
      }
    }
  } else {
    console.log("Tidak ada panggilan fungsi ditemukan dalam respons.");
    console.log(response.text);
  }

}

main().catch(console.error);